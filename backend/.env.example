# ============================================================
# REQUIRED CONFIGURATION
# ============================================================

# GitHub Configuration (REQUIRED)
# Create a personal access token at https://github.com/settings/tokens
# with repo and issues scopes. Set GITHUB_REPO to your own fork/copy
# of the ProgramAT repository — this is where tools will be read from and
# where Copilot will write new tools created via issues.
GITHUB_TOKEN=your_github_token_here
GITHUB_REPO=username/your-programat-fork

# Gemini Configuration (REQUIRED)
# Obtain an API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3-flash-preview

# Optional provider keys for LiteLLM-compatible models
# Set these if you plan to switch LLM_MODEL to OpenAI, Anthropic, or OpenRouter models.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Active model used by the backend and most tools.
# Keep the default Gemini model unless you want to switch providers.
# Examples: gemini-3-flash-preview, gpt-4o, claude-3-5-sonnet-20241022
LLM_MODEL=gemini-3-flash-preview

# Google Cloud Vision (REQUIRED for OCR-based tools)
# 1. Create a GCP project at https://console.cloud.google.com
# 2. Enable the Cloud Vision API
# 3. Create a service account and download the JSON key file
# 4. Set this to the absolute path of that JSON file on your server
# If omitted, OCR tools will be disabled but all other features still work.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ============================================================
# SERVER CONFIGURATION
# ============================================================

HOST=0.0.0.0
PORT=8080
PAUSE_DURATION=5.0

# ============================================================
# OPTIONAL CONFIGURATION
# ============================================================

# GCP Secret Manager (overrides the values above if configured)
# Only needed if you are managing secrets via GCP — most self-hosted
# deployments should leave these commented out and use the values above.
# GCP_PROJECT=your-project-id
# GITHUB_SECRET_ID=GITHUB_TOKEN
